<!-- Schema bolumu -->
<details class="schema-block">
  <summary>
    <span class="badge badge-{{ schema.schema_quality_grade|lower|replace('/', '') }}">
      {{ schema.schema_quality_grade }}
    </span>
    <strong>{{ schema.schema_name }}</strong>
    <span style="color:var(--text-muted); font-size:13px;">
      &mdash; {{ schema.table_count }} tablo, {{ "{:,}".format(schema.total_rows) }} satir{% if schema.total_size_display %}, {{ schema.total_size_display }}{% endif %}
    </span>
  </summary>
  <div class="content">
    <table class="sortable">
      <thead>
        <tr>
          <th>Tablo</th>
          <th>Satir</th>
          <th>Boyut</th>
          <th>Kolon</th>
          <th>Kalite</th>
          <th>Not</th>
          <th>Sure</th>
        </tr>
      </thead>
      <tbody>
      {% for table in schema.tables %}
        <tr class="filterable">
          <td>
            <a href="#table-{{ schema.schema_name }}-{{ table.table_name }}"
               style="color:var(--accent); text-decoration:none;">
              {{ table.table_name }}
            </a>
          </td>
          <td>{{ "{:,}".format(table.row_count) }}{% if table.row_count_estimated %} *{% endif %}</td>
          <td>{{ table.table_size_display or "-" }}</td>
          <td>{{ table.column_count }}</td>
          <td>{% if table.table_quality_grade != 'N/A' %}{{ "%.1f"|format(table.table_quality_score * 100) }}%{% else %}-{% endif %}</td>
          <td><span class="badge badge-{{ table.table_quality_grade|lower|replace('/', '') }}">{{ table.table_quality_grade }}</span></td>
          <td>{{ table.profile_duration_sec }}s</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>

    <!-- Tablo detaylari -->
    {% for table in schema.tables %}
    {% include "partials/table_detail.html.j2" %}
    {% endfor %}
  </div>
</details>
